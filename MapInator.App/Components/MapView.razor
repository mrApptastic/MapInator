@inject MapInteropService MapService

<div id="map-container" class="flex-grow-1 position-relative">
    <div id="map" style="width:100%;height:100%;min-height:400px;"></div>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await MapService.InitMapAsync("map");
    }

    public async Task AddLayerAsync(string filePath) =>
        await MapService.AddLayerAsync(filePath);

    public async Task RemoveLayerAsync(string filePath) =>
        await MapService.RemoveLayerAsync(filePath);
}
